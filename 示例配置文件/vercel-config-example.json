{
  "version": 2,
  "name": "my-hexo-blog",
  "build": {
    "env": {
      "NODE_VERSION": "18"
    }
  },
  "buildCommand": "npm install && npm install hexo-cli -g && hexo generate",
  "outputDirectory": "public",
  "framework": "hexo",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
